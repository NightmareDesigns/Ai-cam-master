# ── server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
SECRET_KEY=change-me-to-a-random-secret

# ── storage ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./aicam.db
RECORDINGS_DIR=./recordings
SNAPSHOTS_DIR=./snapshots
MAX_RECORDING_DAYS=30

# ── detection ────────────────────────────────────────────────────────────────
# YOLOv8 model: yolov8n / yolov8s / yolov8m / yolov8l / yolov8x
YOLO_MODEL=yolov8n.pt
DETECTION_CONFIDENCE=0.45
# Comma-separated COCO class names to track (empty = all)
TRACKED_CLASSES=person,car,truck,bus,motorcycle,bicycle,dog,cat

# ── streaming ────────────────────────────────────────────────────────────────
STREAM_FPS=10
STREAM_JPEG_QUALITY=75

# ── alerts ───────────────────────────────────────────────────────────────────
ALERT_COOLDOWN_SECONDS=30

# ── email notifications (optional) ───────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# ── auto-discovery ───────────────────────────────────────────────────────────
# Enable automatic camera discovery and credential testing on startup
AUTO_DISCOVERY_ENABLED=true
AUTO_DISCOVERY_ON_STARTUP=true
AUTO_DISCOVERY_BRUTE_FORCE=true
AUTO_DISCOVERY_AUTO_ADD=true
AUTO_DISCOVERY_MAX_HOSTS=256
AUTO_DISCOVERY_TIMEOUT=2.0
AUTO_DISCOVERY_INTERVAL_HOURS=24
# Comma-separated list of subnets (e.g., 192.168.1.0/24,10.0.0.0/24), leave empty to auto-detect
AUTO_DISCOVERY_SUBNETS=
